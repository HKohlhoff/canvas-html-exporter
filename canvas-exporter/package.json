{
  "name": "canvas-exporter",
  "version": "0.1.0",
  "description": "Export Obsidian Canvas to interactive HTML",
  "main": "main.js",
  "scripts": {
    "build": "node build.mjs",
    "test": "npm run test:math && npm run test:markdown",
    "test:math": "tsc -p tsconfig.tests.json && node .test-build/tests/math-rendering.test.js",
    "test:markdown": "tsc -p tsconfig.tests.json && node .test-build/tests/markdown-rendering.test.js",
    "dev": "node build.mjs --watch",
    "build:prod": "node build.mjs --production",
    "dev:prod": "node build.mjs --watch --production"
  },
  "keywords": [],
  "author": "Holger Kohlhoff",
  "license": "MIT",
  "dependencies": {
    "katex": "^0.16.0"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/katex": "^0.16.0"
  }
}
